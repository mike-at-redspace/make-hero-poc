    "tw-animate-css": "latest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "latest",
    "oxfmt": "0.9.0",
    "oxlint": "1.6.0",
    "tailwindcss": "latest",
    "typescript": "5.7.3",
    "vite": "latest"
  },
  "pnpm": {
    "overrides": {
      "vite": "latest"
    }
